# WorkTicket Backend — Development Configuration
# Copy this file to .env and fill in your local values.
# DO NOT commit real secrets to version control.
#
# WARNING: This file uses safe defaults for local development only.
# For production setup, see .env.example at the src/ directory.

APP_NAME=WorkTicket API
DEBUG=true

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=workticket

# Database — uses local postgres by default
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/workticket
REDIS_URL=redis://localhost:6379/0
REDIS_BROKER_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/0
REDIS_PASSWORD=dev-redis-password

# Clerk authentication — set these in your local .env (DO NOT commit secrets)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWT_ISSUER=
CLERK_JWT_AUDIENCE=

# AI — disabled by default in v1 (manual-first MVP)
AI_DISABLED=true

# AI — local-only defaults (not needed when AI_DISABLED=true)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEXT_MODEL=llama3.1
OLLAMA_VISION_MODEL=llama3.2-vision
OLLAMA_TIMEOUT=300

WHISPER_MODEL_SIZE=base
WHISPER_SERVICE_URL=http://localhost:8001
WHISPER_API_KEY=

# R2/Cloudflare storage — set real values for production
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Stripe — set real values for production
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Observability — set DSN to enable error tracking
SENTRY_DSN=
METRICS_ACCESS_TOKEN=

# CORS & Security
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
ALLOWED_HOSTS=localhost,127.0.0.1
ALLOWED_DOMAINS=

# Celery — required for production
CELERY_TASK_SIGNING_KEY=dev-signing-key-not-for-production

# Other
DEPLOY_ID=dev
UVICORN_WORKERS=4
WS_ENABLED=true
WS_WORKER_REPLICAS=5
