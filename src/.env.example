# WorkTicket Docker Compose Environment
# Copy to .env and fill in secrets
# DO NOT commit real secrets to version control

APP_NAME=WorkTicket API
DEBUG=true

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=workticket

# Redis
REDIS_PASSWORD=dev-redis-password

# Clerk authentication
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWT_ISSUER=
CLERK_JWT_AUDIENCE=

# AI — disabled by default in v1 (manual-first MVP)
# To re-enable, set AI_DISABLED=false and start AI services
AI_DISABLED=true

# AI service URLs (required only when AI_DISABLED=false)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_TEXT_MODEL=llama3.1
OLLAMA_VISION_MODEL=llama3.2-vision
OLLAMA_TIMEOUT=300

WHISPER_MODEL_SIZE=base
WHISPER_SERVICE_URL=http://whisper-service:8001

# Cloudflare R2 — set real values for production
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Stripe — set real values for production
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Observability
SENTRY_DSN=
METRICS_ACCESS_TOKEN=

# CORS & Security
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
ALLOWED_HOSTS=localhost,127.0.0.1
ALLOWED_DOMAINS=

# Celery
CELERY_TASK_SIGNING_KEY=dev-signing-key-not-for-production
CELERY_DEFAULT_CONCURRENCY=2

# Misc
DEPLOY_ID=dev
UVICORN_WORKERS=4
WS_ENABLED=true
WS_WORKER_REPLICAS=5
